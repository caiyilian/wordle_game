[Unit]
Description=Wordle Game FastAPI Server
After=network.target postgresql.service

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/wordle/backend
Environment=PATH=/opt/wordle/venv/bin
EnvironmentFile=/opt/wordle/.env
ExecStart=/opt/wordle/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 4
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
